# 把这个文件复制为 .env，然后填入你的 API Key
# 获取 Key 的地址：https://platform.openai.com/api-keys
# 注册 OpenAI 账号后，在 API Keys 页面创建一个新的 Key
OPENAI_API_KEY=sk-your-api-key-here

# 默认使用的 LLM 模型名称（可按需修改）
# 例如：gpt-4o-mini, gpt-4o, gpt-3.5-turbo 等
DEFAULT_LLM_PROVIDER=gpt-4o-mini

# API 基础地址（可选，用于兼容第三方 OpenAI 接口）
# 如果你使用的是 OpenAI 官方 API，可以不设置这一项
# 如果你使用代理或第三方兼容服务，填入对应的地址
# 例如：https://your-proxy.example.com/v1
BASE_URL=
